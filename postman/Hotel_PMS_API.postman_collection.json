    {
      "name": "Reservations",
      "item": [
        {
          "name": "Create Reservation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('reservation_id', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guest_id\": \"{{guest_id}}\",\n  \"room_id\": \"{{room_id}}\",\n  \"check_in_date\": \"2026-03-01\",\n  \"check_out_date\": \"2026-03-05\",\n  \"adults\": 2,\n  \"children\": 0,\n  \"special_requests\": \"Late check-in, please\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/v1/reservations/", "host": ["{{base_url}}"], "path": ["api", "v1", "reservations", ""] }
          }
        },
        {
          "name": "List Reservations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/reservations/?skip=0&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "reservations", ""],
              "query": [
                { "key": "guest_id", "value": "{{guest_id}}", "disabled": true },
                { "key": "room_id",  "value": "{{room_id}}",  "disabled": true },
                { "key": "status",   "value": null, "description": "confirmed | checked_in | checked_out | cancelled | no_show", "disabled": true },
                { "key": "skip",     "value": "0" },
                { "key": "limit",    "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Reservation",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/reservations/{{reservation_id}}", "host": ["{{base_url}}"], "path": ["api", "v1", "reservations", "{{reservation_id}}"] }
          }
        },
        {
          "name": "Update Reservation",
          "request": {
            "method": "PATCH",
