{
  "info": {
    "name": "Hotel PMS API",
    "description": "Property Management System — all endpoints with auto-token handling and chained variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url",        "value": "http://localhost:8000" },
    { "key": "access_token",    "value": "" },
    { "key": "refresh_token",   "value": "" },
    { "key": "user_id",         "value": "" },
    { "key": "guest_id",        "value": "" },
    { "key": "room_type_id",    "value": "" },
    { "key": "room_id",         "value": "" },
    { "key": "reservation_id",  "value": "" },
    { "key": "folio_id",        "value": "" },
    { "key": "line_item_id",    "value": "" },
    { "key": "oauth_client_id", "value": "" },
    { "key": "client_id",       "value": "" },
    { "key": "client_secret",   "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (password grant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('access_token',  json.access_token);",
                  "pm.collectionVariables.set('refresh_token', json.refresh_token ?? '');",
                  "pm.test('Login successful', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password" },
                { "key": "username",   "value": "admin@hotel.com" },
                { "key": "password",   "value": "changeme" }
              ]
            },
            "url": { "raw": "{{base_url}}/auth/token", "host": ["{{base_url}}"], "path": ["auth", "token"] }
          }
        },
        {
          "name": "Client Credentials Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access_token);",
                  "pm.test('Client token issued', () => pm.response.to.have.status(200));",
                  "pm.test('No refresh token', () => pm.expect(json.refresh_token).to.be.null);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type",    "value": "client_credentials" },
                { "key": "client_id",     "value": "{{client_id}}" },
                { "key": "client_secret", "value": "{{client_secret}}" }
              ]
            },
            "url": { "raw": "{{base_url}}/auth/token", "host": ["{{base_url}}"], "path": ["auth", "token"] }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('access_token',  json.access_token);",
                  "pm.collectionVariables.set('refresh_token', json.refresh_token ?? '');"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/refresh", "host": ["{{base_url}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"] }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "OAuth Clients",
          "item": [
            {
              "name": "Create Client",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json();",
                      "if (json.id)          pm.collectionVariables.set('oauth_client_id', json.id);",
                      "if (json.client_id)   pm.collectionVariables.set('client_id',       json.client_id);",
                      "if (json.client_secret) pm.collectionVariables.set('client_secret', json.client_secret);",
                      "pm.test('Client created', () => pm.response.to.have.status(201));",
                      "pm.test('Secret returned once', () => pm.expect(json.client_secret).to.be.a('string'));"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"My Integration Service\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{base_url}}/auth/clients", "host": ["{{base_url}}"], "path": ["auth", "clients"] }
              }
            },
            {
              "name": "List Clients",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/auth/clients?skip=0&limit=20",
                  "host": ["{{base_url}}"],
                  "path": ["auth", "clients"],
                  "query": [
                    { "key": "skip",  "value": "0" },
                    { "key": "limit", "value": "20" }
                  ]
                }
              }
            },
            {
              "name": "Get Client",
              "request": {
                "method": "GET",
                "url": { "raw": "{{base_url}}/auth/clients/{{oauth_client_id}}", "host": ["{{base_url}}"], "path": ["auth", "clients", "{{oauth_client_id}}"] }
              }
            },
            {
              "name": "Rotate Secret",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json();",
                      "if (json.client_id)     pm.collectionVariables.set('client_id',     json.client_id);",
                      "if (json.client_secret) pm.collectionVariables.set('client_secret', json.client_secret);",
                      "pm.test('Secret rotated', () => pm.response.to.have.status(200));"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "url": { "raw": "{{base_url}}/auth/clients/{{oauth_client_id}}/rotate-secret", "host": ["{{base_url}}"], "path": ["auth", "clients", "{{oauth_client_id}}", "rotate-secret"] }
              }
            },
            {
              "name": "Delete Client",
              "request": {
                "method": "DELETE",
                "url": { "raw": "{{base_url}}/auth/clients/{{oauth_client_id}}", "host": ["{{base_url}}"], "path": ["auth", "clients", "{{oauth_client_id}}"] }
              }
            }
          ]
        }
      ]
    },
