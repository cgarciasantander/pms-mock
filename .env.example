# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pms_user:pms_secret@localhost:5432/pms_db
POSTGRES_USER=pms_user
POSTGRES_PASSWORD=pms_secret
POSTGRES_DB=pms_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme-replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── pgAdmin (docker-compose only) ─────────────────────────────────────────────
PGADMIN_EMAIL=admin@pms.local
PGADMIN_PASSWORD=admin
